# Supabase Configurations
# Obtain these from your Supabase Dashboard: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configurations
# Obtain these from your Stripe Dashboard (Developers -> API keys & Webhooks)
STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_PRICE_ID=price_your_recurring_price_id

# Stripe Webhooks (CLI webhook secret is for local testing, standard is for production)
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret
STRIPE_CLI_WEBHOOK_SECRET=whsec_your_local_cli_webhook_secret

# Application URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
